# --- Google Service Account ---
# path ของไฟล์ JSON key (ดู docs/google_setup.md เพื่อสร้าง)
GOOGLE_SERVICE_ACCOUNT_PATH=./secrets/service_account.json

# --- Google Sheet ---
# ID ของไฟล์ "เรเบเกอรี่-ฐานข้อมูลส่งสินค้า"
SHEET_ID=1yWBbE_ZPKYaRgg6nYl9TxbUZ0AnUSDDxLvQEJwua6Lk

# --- Google Drive ---
# โฟลเดอร์หลักโครงการ (เก็บรูป + บิล PDF)
DRIVE_FOLDER_ID=1Gd-kIge5zbIR_D44hGaZjxwCXEmMr5n1
# โฟลเดอร์ "ระบบบันทึกส่งสินค้าเบเกอรี่"
SUBFOLDER_ID=1GPqWbNVZaV0YqSXHWtL0a1EcISs_c-CR

# --- App config ---
TIMEZONE=Asia/Bangkok
APP_TITLE=เรเบเกอรี่ — ระบบส่งสินค้า

# --- Local image storage ---
# รูปสินค้า/สต็อกเก็บบน disk ของเครื่อง (ไม่ใช้ Drive — Service Account ไม่มี quota)
# dev: ปล่อยว่างได้ (ดีฟอลต์ = ./data/images)
# Proxmox: ชี้ไป volume ถาวรที่ vzdump/snapshot ครอบไว้ เช่น /mnt/data/rae-bakery/images
# IMAGES_DIR=/mnt/data/rae-bakery/images

# --- SQLite database (Phase 1: แทน Google Sheets) ---
# ไฟล์ฐานข้อมูล SQLite — dev: ปล่อยว่างได้ (ดีฟอลต์ = ./data/app.db)
# Proxmox: ชี้ไป local volume ที่ backup ครอบไว้ (WAL ต้องการ local fs — ห้าม NFS/CIFS)
# DB_PATH=/mnt/data/rae-bakery/app.db

# --- Auth (streamlit-authenticator) ---
# path ของ auth config (ดู docs/auth_setup.md)
AUTH_CONFIG_PATH=./auth_config.yaml
COOKIE_NAME=rae_bakery_auth
COOKIE_KEY=change-me-to-a-random-string
COOKIE_EXPIRY_DAYS=30
